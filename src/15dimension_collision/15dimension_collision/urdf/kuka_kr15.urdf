<?xml version="1.0"?>
<!--
  URDF: KUKA KR15 — célula robotizada
  Paquete ROS 2: 15dimension_collision

  Meshes reales (unidades originales en mm → ROS 2 usa metros, scale 0.001):
    kr15_1_0.stl  →  base        bbox: 796 × 471 × 901 mm   centroid: (-25, -124, 120)
    kr15_1_1.stl  →  link_1      bbox: 735 × 529 × 490 mm   centroid: (107, -16, 70)
    kr15_1_2.stl  →  link_2      bbox: 827 × 199 × 246 mm   centroid: (314, 0, -123)
    kr15_1_3.stl  →  link_3      bbox: 374 × 592 × 298 mm   centroid: (53, -11, 69)
    kr15_1_4.stl  →  link_4      bbox: 152 × 200 × 376 mm   centroid: (0, 2, 127)
    kr15_1_5.stl  →  link_5      bbox: 148 × 203 × 127 mm   centroid: (0, 1, 2)
    kr15_1_6.stl  →  link_6      bbox: 118 × 118 × 37 mm    centroid: (0, 0, 18)

  Parámetros DH originales (C# NXOpen):
    alpha = [0,    0,     π/2,   0,     π/2,   π/2,  -π/2]
    a     = [0,    0,     300,   650,   155,   0,     0   ]  mm
    d     = [0,    0,     675,   0,     0,     600,   0   ]  mm
    theta = [0,    0,     π/2,   0,     0,     0,     0   ]  offset

  Colisión: primitivas geométricas ajustadas a los bounding boxes reales
-->

<robot name="kuka_kr15">

  <!-- ================================================================
       WORLD — frame de referencia fijo
       ================================================================ -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>


  <!-- ================================================================
       BASE LINK
       STL bbox: 796 × 471 × 901 mm  (el volumen incluye el link_1 en posición home)
       Colisión conservadora: caja 500 × 400 × 200 mm (solo la parte fija)
       ================================================================ -->
  <link name="base_link">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://15dimension_collision/meshes/kr15_1_0.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="kuka_orange">
        <color rgba="1.0 0.45 0.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="-0.025 -0.124 0.10" rpy="0 0 0"/>
      <geometry>
        <box size="0.50 0.40 0.20"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="50.0"/>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <inertia ixx="0.8" iyy="0.8" izz="0.6"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

  </link>


  <!-- ================================================================
       JOINT 1 — Rotación Z
       d = 675 mm = 0.675 m
       ================================================================ -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.675" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159"
           effort="200" velocity="1.745"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>


  <!-- ================================================================
       LINK 1 — Columna giratoria
       STL bbox: 735 × 529 × 490 mm  centroid: (107, -16, 70)
       Colisión: cilindro Ø300mm × 490mm centrado en el centroide
       ================================================================ -->
  <link name="link_1">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://15dimension_collision/meshes/kr15_1_1.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="kuka_orange"/>
    </visual>

    <collision>
      <origin xyz="0.107 -0.016 0.07" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.49"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="12.0"/>
      <origin xyz="0.107 -0.016 0.07" rpy="0 0 0"/>
      <inertia ixx="0.3" iyy="0.3" izz="0.1"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

  </link>


  <!-- ================================================================
       JOINT 2 — Hombro (pitch)
       a = 300 mm = 0.300 m,  alpha = π/2,  theta_offset = π/2
       ================================================================ -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0.300 0 0" rpy="1.5708 1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9671" upper="2.9671"
           effort="200" velocity="1.745"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>


  <!-- ================================================================
       LINK 2 — Brazo superior (el más largo)
       STL bbox: 827 × 199 × 246 mm  centroid: (314, 0, -123)
       Colisión: cilindro Ø200mm × 827mm a lo largo del eje X
       ================================================================ -->
  <link name="link_2">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://15dimension_collision/meshes/kr15_1_2.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="kuka_orange"/>
    </visual>

    <collision>
      <origin xyz="0.314 0 -0.123" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.10" length="0.827"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="10.0"/>
      <origin xyz="0.314 0 -0.123" rpy="0 0 0"/>
      <inertia ixx="0.05" iyy="0.40" izz="0.40"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

  </link>


  <!-- ================================================================
       JOINT 3 — Codo
       a = 650 mm = 0.650 m,  alpha = 0
       ================================================================ -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0.650 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9671" upper="2.9671"
           effort="150" velocity="1.920"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>


  <!-- ================================================================
       LINK 3 — Antebrazo
       STL bbox: 374 × 592 × 298 mm  centroid: (53, -11, 69)
       Colisión: caja que envuelve el antebrazo
       ================================================================ -->
  <link name="link_3">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://15dimension_collision/meshes/kr15_1_3.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="kuka_orange"/>
    </visual>

    <collision>
      <origin xyz="0.053 -0.011 0.069" rpy="0 0 0"/>
      <geometry>
        <box size="0.374 0.30 0.298"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="6.0"/>
      <origin xyz="0.053 -0.011 0.069" rpy="0 0 0"/>
      <inertia ixx="0.05" iyy="0.10" izz="0.10"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

  </link>


  <!-- ================================================================
       JOINT 4 — Muñeca 1
       a = 155 mm,  d = 600 mm,  alpha = π/2
       ================================================================ -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0.155 0 0.600" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159"
           effort="54" velocity="2.967"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>


  <!-- ================================================================
       LINK 4 — Muñeca 1
       STL bbox: 152 × 200 × 376 mm  centroid: (0, 2, 127)
       Colisión: cilindro vertical Ø152mm × 376mm
       ================================================================ -->
  <link name="link_4">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://15dimension_collision/meshes/kr15_1_4.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="kuka_orange"/>
    </visual>

    <collision>
      <origin xyz="0.0 0.002 0.127" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.076" length="0.376"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="3.5"/>
      <origin xyz="0.0 0.002 0.127" rpy="0 0 0"/>
      <inertia ixx="0.02" iyy="0.02" izz="0.008"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

  </link>


  <!-- ================================================================
       JOINT 5 — Muñeca 2
       alpha = π/2
       ================================================================ -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159"
           effort="54" velocity="2.967"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>


  <!-- ================================================================
       LINK 5 — Muñeca 2
       STL bbox: 148 × 203 × 127 mm  centroid: (0, 1, 2)
       Colisión: esfera Ø150mm (articulación casi cúbica)
       ================================================================ -->
  <link name="link_5">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://15dimension_collision/meshes/kr15_1_5.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="kuka_orange"/>
    </visual>

    <collision>
      <origin xyz="0.0 0.001 0.002" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.075"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="2.5"/>
      <origin xyz="0.0 0.001 0.002" rpy="0 0 0"/>
      <inertia ixx="0.008" iyy="0.008" izz="0.008"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

  </link>


  <!-- ================================================================
       JOINT 6 — Flange
       alpha = -π/2
       ================================================================ -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159"
           effort="36" velocity="3.316"/>
    <dynamics damping="0.2" friction="0.02"/>
  </joint>


  <!-- ================================================================
       LINK 6 — Flange (brida de herramienta)
       STL bbox: 118 × 118 × 37 mm  centroid: (0, 0, 18)
       Colisión: cilindro plano Ø118mm × 37mm
       ================================================================ -->
  <link name="link_6">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://15dimension_collision/meshes/kr15_1_6.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="kuka_orange"/>
    </visual>

    <collision>
      <origin xyz="0.0 0.0 0.018" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.059" length="0.037"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1.5"/>
      <origin xyz="0.0 0.0 0.018" rpy="0 0 0"/>
      <inertia ixx="0.003" iyy="0.003" izz="0.003"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

  </link>


  <!-- ================================================================
       TCP — Tool Center Point
       140 mm por delante del flange (eje Z del link_6)
       ================================================================ -->
  <joint name="joint_tcp" type="fixed">
    <parent link="link_6"/>
    <child link="tcp"/>
    <origin xyz="0 0 0.140" rpy="0 0 0"/>
  </joint>

  <link name="tcp"/>

</robot>
